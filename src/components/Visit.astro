---
<section class="visit" id="visita">
  <div class="wrap visit__grid">
    <div class="reveal reveal--left">
      <span style="display:inline-block;background:rgba(255,210,63,0.15);color:var(--yellow);padding:6px 14px;border-radius:999px;font-weight:800;font-size:12px;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:14px;">Visítanos</span>
      <h2>Pásate por <span class="yellow">Delicias</span></h2>
      <div class="info-block">
        <h3>Dirección</h3>
        <p>Avenida de Madrid, 162<br/>50010 · Zaragoza</p>
      </div>
      <div class="info-block">
        <h3>Horario</h3>
        <p>Todos los días<br/>12:30 – 16:30 · 19:30 – 23:30</p>
      </div>
      <div class="info-block">
        <h3>Pedidos a domicilio</h3>
        <p><a href="https://glovoapp.com/es/es/zaragoza/stores/zaza-stop-zaragoza" target="_blank" rel="noopener" style="color:var(--yellow);text-decoration:underline;">Glovo · Zaza Stop Zaragoza</a></p>
      </div>
      <div class="info-block">
        <h3>Síguenos</h3>
        <p><a href="https://www.instagram.com/zazastop_/" target="_blank" rel="noopener" style="color:var(--yellow);text-decoration:underline;">@zazastop_ en Instagram</a></p>
      </div>
    </div>
    <div class="map-frame reveal reveal--right">
      <iframe
        src="https://www.google.com/maps?q=Avenida+de+Madrid+162,+Zaragoza&output=embed"
        loading="lazy"
        title="Mapa ZazaStop"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
