---
const links = [
  { href: '#crousty', label: 'Crousty' },
  { href: '#menu', label: 'Menú' },
  { href: '#crea-tu-taco', label: 'Crea tu Taco' },
  { href: '#visita', label: 'Visítanos' }
];
---
<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <img src="/images/brand/logo.jpg" alt="ZazaStop" />
      <span>ZAZASTOP</span>
    </a>
    <nav class="nav__links" aria-label="Navegación principal">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="nav__cta">
      <a class="btn btn--yellow nav__order" href="https://glovoapp.com/es/es/zaragoza/stores/zaza-stop-zaragoza" target="_blank" rel="noopener">Glovo</a>
      <a class="btn btn--outline nav__order" href="https://www.ubereats.com/es/store/zaza-stop/uV8iuTk-WYmK1vmhvFz-nw" target="_blank" rel="noopener">Uber Eats</a>
      <button class="nav__toggle" aria-label="Abrir menú" aria-expanded="false">
        <span></span>
      </button>
    </div>
  </div>
</header>
