---
const picks = [
  {
    name: 'Crousty',
    tag: 'EL Nº1 DE LA CASA',
    desc: 'Arroz, tenders crujientes, salsa secreta, sweet chilli, cebolla crujiente y orégano.',
    price: 'Desde 7,90€',
    img: '/images/products/crousty-normal.jpg',
    href: '#crousty'
  },
  {
    name: 'Taco XL',
    tag: 'XXL · 3 carnes · 3 salsas',
    desc: 'Tortilla planchada, gratinada, rellena hasta arriba. El taco francés más bestia de Zaragoza.',
    price: '10,90€',
    img: '/images/products/taco-xl.jpg',
    href: '#crea-tu-taco'
  },
  {
    name: 'Patatas Bacon Cheddar',
    tag: 'Sí, las que has visto en Insta',
    desc: 'Patatas crujientes, bacon de pavo y cheddar fundido por encima. Imposible parar.',
    price: '3,50€',
    img: '/images/products/patatas-con-queso-y-cebolla.png',
    href: '#menu'
  }
];
---
<section class="best">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Top de la casa</span>
      <h2>Lo que <span class="scribble-circle">todos piden</span></h2>
      <p>Tres productos que no fallan. Recién hechos, sin atajos, con las salsas de la casa.</p>
    </div>
    <div class="best__grid">
      {picks.map(p => (
        <a class="best__card" href={p.href}>
          <div class="best__img">
            <img src={p.img} alt={p.name} />
          </div>
          <div class="best__body">
            <span class="best__tag">{p.tag}</span>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <div class="best__foot">
              <span class="best__price">{p.price}</span>
              <span class="best__arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
