---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap">
    <img class="footer__logo" src="/images/brand/logo.jpg" alt="ZazaStop" />
    <h3 style="margin:0;font-size:24px;letter-spacing:0.05em;">ZAZASTOP</h3>
    <p style="margin:6px 0 0;opacity:0.85;">Tacos franceses & Crousty · Av. Madrid 162, Zaragoza</p>
    <div class="footer__socials">
      <a href="https://www.instagram.com/zazastop_/" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
      <a href="https://glovoapp.com/es/es/zaragoza/stores/zaza-stop-zaragoza" target="_blank" rel="noopener" aria-label="Glovo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18l-2 13H5L3 3z"></path><circle cx="9" cy="20" r="1.5"></circle><circle cx="17" cy="20" r="1.5"></circle></svg>
      </a>
    </div>
    <p class="footer__small">© {year} ZazaStop · Hecho con cariño en Zaragoza</p>
  </div>
</footer>
