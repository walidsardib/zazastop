<section class="story-strip" id="historia">
  <div class="wrap reveal">
    <div class="story-strip__inner">
      <div class="story-strip__text">
        <span class="eyebrow" style="display:inline-block;background:rgba(255,210,63,0.18);color:var(--yellow);padding:6px 14px;border-radius:999px;font-weight:800;font-size:12px;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:12px;">Receta original</span>
        <h2>Sabor de Lyon, <span class="yellow">hecho en Delicias</span>.</h2>
        <p>
          Tres amigos del barrio trayendo el taco francés y el primer Crousty
          de Zaragoza. Receta original, ingredientes frescos, salsas de la casa.
        </p>
      </div>
      <div class="story-strip__pills">
        <span class="pill-dark">Av. Madrid 162</span>
        <span class="pill-dark">Las Delicias</span>
        <span class="pill-dark">98% en Glovo</span>
      </div>
    </div>
  </div>
</section>
