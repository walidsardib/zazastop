---
<section class="story-strip" id="historia">
  <div aria-hidden="true" class="story-strip__bg-blob story-strip__bg-blob--1"></div>
  <div aria-hidden="true" class="story-strip__bg-blob story-strip__bg-blob--2"></div>
  <div class="wrap">
    <div class="story-strip__inner reveal">
      <figure class="story-strip__polaroid">
        <img src="/images/brand/localfuera.webp" alt="Fachada de ZazaStop con persiana morada y mascota" loading="lazy" />
        <figcaption>Av. Madrid 162 · Delicias</figcaption>
      </figure>
      <div class="story-strip__body">
        <span class="story-strip__eyebrow">Receta original</span>
        <h2>Sabor de Lyon,<br/><span class="yellow">hecho en Delicias</span>.</h2>
        <p>
          Tres amigos del barrio trayendo el taco francés y el primer Crousty
          de Zaragoza. Receta original, ingredientes frescos, salsas de la casa.
        </p>
        <div class="story-strip__pills">
          <span class="pill-dark">Las Delicias</span>
          <span class="pill-dark">Hecho a mano</span>
          <span class="pill-dark">98% en Glovo</span>
        </div>
      </div>
    </div>
  </div>
</section>
